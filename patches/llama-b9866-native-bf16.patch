+template <int block_size, bool affine_bf16>
+static __global__ void norm_bf16_fused(
+        const nv_bfloat16 * x, const void * scale_ptr, const void * shift_ptr,
+        nv_bfloat16 * dst, const int ncols, const int64_t x_stride_row,
+        const int64_t scale_stride_row, const int64_t shift_stride_row,
+        const float eps) {
+    const int row = blockIdx.x;
+    const int tid = threadIdx.x;
+    x += row * x_stride_row;
+    dst += row * ncols;
+    float sum = 0.0f;
+    for (int col = tid; col < ncols; col += block_size) {
+        sum += __bfloat162float(x[col]);
+    }
+    extern __shared__ float s_sum[];
+    sum = block_reduce<block_reduce_method::SUM, block_size>(sum, s_sum);
+    const float mean = sum / ncols;
+    float var_sum = 0.0f;
+    for (int col = tid; col < ncols; col += block_size) {
+        const float centered = __bfloat162float(x[col]) - mean;
+        var_sum += centered * centered;
+    }
+    var_sum = block_reduce<block_reduce_method::SUM, block_size>(var_sum, s_sum);
+    const float var = var_sum / ncols;
+    const float inv_std = rsqrtf(var + eps);
+    if constexpr (affine_bf16) {
+        const nv_bfloat16 * scale = (const nv_bfloat16 *) scale_ptr + row * scale_stride_row;
+        const nv_bfloat16 * shift = (const nv_bfloat16 *) shift_ptr + row * shift_stride_row;
+        for (int col = tid; col < ncols; col += block_size) {
+            const float normalized = (__bfloat162float(x[col]) - mean) * inv_std;
+            dst[col] = __float2bfloat16(normalized * __bfloat162float(scale[col]) +
+                                        __bfloat162float(shift[col]));
+        }
+    } else {
+        const float * scale = (const float *) scale_ptr + row * scale_stride_row;
